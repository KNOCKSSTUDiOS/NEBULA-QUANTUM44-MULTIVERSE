apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: basefounder
  annotations:
    kubernetes.io/ingress.class: "gce"
spec:
  rules:
  - host: basefounder.test.com
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: basefounder-loadbalancer
            port:
              number: 8765
